                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <GroupBox Grid.Row="0" Header="CSV Import">
                                <StackPanel>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8">
                                        Select a folder containing CSV files (channels.csv, contacts.csv, zones.csv, grouplists.csv, scanlists.csv, rxgroups.csv) to import into the active codeplug editor.
                                    </TextBlock>
                                    <Button Content="📂 Import CSV Folder..." Command="{Binding CsvWorkspace.ImportCommand}"
                                            HorizontalAlignment="Left" />
                                    <TextBlock Margin="0,8,0,0" Text="{Binding CsvWorkspace.ImportSummary}" TextWrapping="Wrap" />
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Grid.Row="1" Header="CSV Export">
                                <StackPanel>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8">
                                        Export the current codeplug as a set of deterministic CSV files for version control, sharing, or external editing.
                                    </TextBlock>
                                    <Button Content="💾 Export CSV Folder..." Command="{Binding CsvWorkspace.ExportCommand}"
                                            HorizontalAlignment="Left" />
                                    <TextBlock Margin="0,8,0,0" Text="{Binding CsvWorkspace.ExportSummary}" TextWrapping="Wrap" />
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Grid.Row="2" Header="Schema Information">
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource MutedBrush}">
                                    Six CSV schemas are supported: channels, contacts, zones, grouplists, scanlists, and rxgroups. 
                                    Each schema has deterministic column headers. The importer reports row-level issues and the 
                                    exporter emits consistent UTF-8 output.
                                </TextBlock>
                            </GroupBox>

                            <GroupBox Grid.Row="3" Header="Import Issues">
                                <ListBox ItemsSource="{Binding CsvWorkspace.ImportIssues}"
                                         Foreground="{StaticResource AmberBrush}"
                                         FontFamily="Consolas" FontSize="11" />
                            </GroupBox>
                        </Grid>
                </TabItem>
                <TabItem Header="🔧 Firmware">
                    <Grid Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <GroupBox Header="Analysis Source">
                                <TextBlock Text="{Binding FirmwareAnalysis.SourceName}" TextWrapping="Wrap" FontFamily="Consolas" />
                            </GroupBox>
                            <GroupBox Grid.Row="1" Header="Summary">
                                <TextBlock Text="{Binding FirmwareAnalysis.Summary}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12" />
                            </GroupBox>
                            <GroupBox Grid.Row="2" Header="Target Compatibility">
                                <DockPanel LastChildFill="True">
                                    <Button DockPanel.Dock="Right" Content="📂 Open Firmware..." Command="{Binding OpenFirmwareImageCommand}" Style="{StaticResource GhostButton}" />
                                    <TextBlock Text="{Binding FirmwareAnalysis.CompatibilitySummary}" TextWrapping="Wrap" Margin="0,0,8,0" />
                                </DockPanel>
                            </GroupBox>
                            <Grid Grid.Row="3" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.1*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                                <GroupBox Header="Checksums &amp; Strings">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="Checksums" Foreground="{StaticResource GoldBrush}" />
                                            <TextBlock Margin="0,4,0,12" Text="{Binding FirmwareAnalysis.Checksums}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="11" />
                                            <TextBlock FontWeight="SemiBold" Text="String Preview" Foreground="{StaticResource GoldBrush}" />
                                            <TextBlock Margin="0,4,0,0" Text="{Binding FirmwareAnalysis.StringPreview}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="11" />
                                        </StackPanel>
                                    </ScrollViewer>
                                </GroupBox>
                                <GroupBox Grid.Column="1" Margin="8,0,0,0" Header="Memory Map">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                        <TextBlock FontFamily="Consolas" FontSize="11" Text="{Binding FirmwareAnalysis.MapPreview}" TextWrapping="NoWrap" />
                                    </ScrollViewer>
                                </GroupBox>
                            </Grid>
                        </Grid>
                </TabItem>
                <TabItem Header="🧪 Advanced">
                    <Grid Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <GroupBox Header="RE Guidance">
                                <DockPanel LastChildFill="True">
                                    <WrapPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0" MaxWidth="980">
                                        <Button Content="✓ Verify Image..." Command="{Binding VerifyImageCommand}" Style="{StaticResource GhostButton}" />
                                        <Button Content="📻 Generate PNW..." Command="{Binding GeneratePnwCodeplugCommand}" Style="{StaticResource GhostButton}" />
                                        <Button Content="📄 Analyze Capture..." Command="{Binding AnalyzeCaptureFileCommand}" Style="{StaticResource GhostButton}" />
                                        <Button Content="🧹 Normalize Capture..." Command="{Binding NormalizeCaptureCommand}" Style="{StaticResource GhostButton}" />
                                        <Button Content="📦 Export Radio JSON..." Command="{Binding ExportCaptureRadioJsonCommand}" Style="{StaticResource GhostButton}" />
                                        <Button Content="📦 Export Radio BIN..." Command="{Binding ExportCaptureRadioBinCommand}" Style="{StaticResource GhostButton}" />
                                        <Button Content="🧠 Analyze Write..." Command="{Binding AnalyzeWriteSessionCommand}" Style="{StaticResource GhostButton}" />
                                        <Button Content="🗺 Map Write..." Command="{Binding MapWriteSessionCommand}" Style="{StaticResource GhostButton}" />
                                        <Button Content="⇄ Diff Images..." Command="{Binding DiffImagesCommand}" Style="{StaticResource GhostButton}" />
                                        <Button Content="🔍 Probe USB" Command="{Binding ProbeUsbPrinterCommand}" Style="{StaticResource GhostButton}" />
                                        <Button Content="📁 Inspect CPS..." Command="{Binding InspectCpsFolderCommand}" Style="{StaticResource GhostButton}" />
                                        <Button Content="📊 Analyze CPS..." Command="{Binding AnalyzeCpsFolderCommand}" Style="{StaticResource GhostButton}" />
                                    </WrapPanel>
                                    <TextBlock Text="{Binding AdvancedTools.Guidance}" TextWrapping="Wrap" FontSize="12"
                                               Foreground="{StaticResource MutedBrush}" Margin="0,0,8,0" />
                                </DockPanel>
                            </GroupBox>
                            <Grid Grid.Row="1" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                                <GroupBox Header="Capture Analysis">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <TextBlock FontFamily="Consolas" FontSize="11" Text="{Binding AdvancedTools.CaptureAnalysisSummary}" TextWrapping="Wrap" />
                                    </ScrollViewer>
                                </GroupBox>
                                <Grid Grid.Column="1" Margin="8,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="1*" />
                                        <RowDefinition Height="1*" />
                                    </Grid.RowDefinitions>
                                    <GroupBox Header="Hex Diff Preview">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <TextBlock FontFamily="Consolas" FontSize="11" Text="{Binding AdvancedTools.HexDiffSummary}" TextWrapping="Wrap" />
                                        </ScrollViewer>
                                    </GroupBox>
                                    <GroupBox Grid.Row="1" Margin="0,8,0,0" Header="USB Printer Probe">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <TextBlock FontFamily="Consolas" FontSize="11" Text="{Binding AdvancedTools.UsbPrinterProbeSummary}" TextWrapping="Wrap" />
                                        </ScrollViewer>
                                    </GroupBox>
                                </Grid>
                            </Grid>
                        </Grid>
                </TabItem>
                <TabItem Header="📡 Trace">
                    <Grid Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel Margin="0,0,0,8">
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Content="Export" Command="{Binding ExportTraceCommand}" Width="80" Style="{StaticResource GhostButton}" />
                                    <Button Content="Clear" Command="{Binding ClearDiagnosticsCommand}" Width="80" />
                                </StackPanel>
                                <TextBlock FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center"
                                           Text="{Binding TransportDiagnostics.Events.Count, StringFormat='Protocol Trace — {0} event(s)'}" />
                            </DockPanel>
                            <ListBox Grid.Row="1" ItemsSource="{Binding TransportDiagnostics.Events}"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas" FontSize="11">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="4,3" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock DockPanel.Dock="Right" FontSize="10"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss.fff}}" />
                                                    <TextBlock FontSize="10" Foreground="{StaticResource GreenBrush}">
                                                        <Run Text="{Binding Direction, Mode=OneWay}" />
                                                        <Run Text=" " />
                                                        <Run Text="{Binding Level, Mode=OneWay}" Foreground="{StaticResource GoldBrush}" />
                                                    </TextBlock>
                                                </DockPanel>
                                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                                                           Foreground="{StaticResource ForegroundBrush}" Margin="0,2,0,0" />
                                                <TextBlock Text="{Binding Payload}" TextWrapping="Wrap"
                                                           Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="0,2,0,0"
                                                           Visibility="{Binding Payload, Converter={StaticResource NonEmptyVis}}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                </TabItem>
            </TabControl>
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}" Margin="4,8" />

            <!-- ═══════════ RIGHT SIDEBAR ═══════════ -->
            <Grid Grid.Column="2" Margin="0,8,8,8" Background="{StaticResource BackgroundBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Backup / Restore -->
                <GroupBox Grid.Row="0" Header="Backup &amp; Restore Status">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="{Binding BackupRestore.StatusMessage}" TextWrapping="Wrap" />
                        <Border Background="#0E130E" CornerRadius="4" Padding="8,6" Margin="0,8,0,0"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding BackupRestore.LatestBackupSummary}" TextWrapping="Wrap" FontSize="11" />
                                <TextBlock Margin="0,4,0,0" Foreground="{StaticResource GreenBrush}"
                                           Text="{Binding BackupRestore.LatestBackupPath}"
                                           TextWrapping="Wrap" FontFamily="Consolas" FontSize="10" />
                            </StackPanel>
                        </Border>
                        <Border Background="#070A07" CornerRadius="4" Padding="8,6" Margin="0,8,0,0"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding BackupRestore.WritePreflightSummary}" TextWrapping="Wrap"
                                           FontWeight="SemiBold" Foreground="{StaticResource AmberBrush}" />
                                <TextBlock Margin="0,4,0,0" Text="{Binding BackupRestore.WritePreflightDetails}"
                                           TextWrapping="Wrap" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource MutedBrush}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </GroupBox>

                <!-- Operation Log -->
                <GroupBox Grid.Row="1" Header="Operation Log">
                    <ListBox ItemsSource="{Binding LogEntries}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="4,4,4,6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right" FontSize="10"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" />
                                            <TextBlock FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{Binding Level, Converter={StaticResource LogLevelBrush}}"
                                                       Text="{Binding Level}" />
                                        </DockPanel>
                                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource ForegroundBrush}"
                                                   Text="{Binding Message}" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </GroupBox>
            </Grid>
        </Grid>

        <!-- ═══════════ STATUS BAR ═══════════ -->
        <Border Grid.Row="3" Background="#070A07"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="16,5">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" FontSize="10" Foreground="{StaticResource MutedBrush}"
                           FontFamily="Consolas" VerticalAlignment="Center">
                    <Run Text="CH:" /><Run Text="{Binding CodeplugEditor.ChannelCount, Mode=OneWay}" />
                    <Run Text=" │ Z:" /><Run Text="{Binding CodeplugEditor.ZoneCount, Mode=OneWay}" />
                    <Run Text=" │ C:" /><Run Text="{Binding CodeplugEditor.ContactCount, Mode=OneWay}" />
                    <Run Text=" │ GL:" /><Run Text="{Binding CodeplugEditor.GroupListCount, Mode=OneWay}" />
                    <Run Text=" │ SL:" /><Run Text="{Binding CodeplugEditor.ScanListCount, Mode=OneWay}" />
                    <Run Text=" │ RX:" /><Run Text="{Binding CodeplugEditor.RxGroupCount, Mode=OneWay}" />
                </TextBlock>
                <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}"
                           Text="{Binding StatusBarText}" VerticalAlignment="Center" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
